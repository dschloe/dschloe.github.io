    <item>
      <title>Ch02 Working with BigQuery</title>
      <link>https://dschloe.github.io/programming/2020/04/ch02_working_with_bigquery/</link>
      <pubDate>Sun, 19 Apr 2020 00:13:30 +0900</pubDate>
