&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;api &lt;span style="color:#f92672"&gt;=&lt;/span&gt; openaq&lt;span style="color:#f92672"&gt;.&lt;/span&gt;OpenAQ()
