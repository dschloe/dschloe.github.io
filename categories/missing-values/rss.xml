&lt;div class="highlight"&gt;&lt;pre tabindex="0" style="color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;"&gt;&lt;code class="language-python" data-lang="python"&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;print(covidtotals&lt;span style="color:#f92672"&gt;.&lt;/span&gt;loc[totvars_misscnt &lt;span style="color:#f92672"&gt;==&lt;/span&gt; &lt;span style="color:#ae81ff"&gt;2&lt;/span&gt;, [&lt;span style="color:#e6db74"&gt;&amp;#39;location&amp;#39;&lt;/span&gt;] &lt;span style="color:#f92672"&gt;+&lt;/span&gt; case_vars]&lt;span style="color:#f92672"&gt;.&lt;/span&gt;T)
